@{
    ViewData["Title"] = "Login";
}

<style>
    body {
        margin: 0;
        background: linear-gradient(135deg, #0f172a, #020617);
        font-family: 'Segoe UI';
        color: white;
    }

    .wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    .card {
        background: #020617;
        padding: 30px;
        border-radius: 12px;
        width: 350px;
        border: 1px solid #1e293b;
        color: white;
    }

    input {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        margin-bottom: 15px;
        border-radius: 8px;
        border: none;
        background: #0f172a;
        color: white;
    }

    button {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        background: #38bdf8;
        border: none;
        font-weight: bold;
    }

    .error {
        color: #ef4444;
    }
</style>

<div class="wrapper">
    <div class="card">
        <h2>Login</h2>

        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

        <form method="post">
            <input type="text" name="username" placeholder="Username" required />
            <input type="password" name="password" placeholder="Password" required />

            <button type="submit">Login</button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}