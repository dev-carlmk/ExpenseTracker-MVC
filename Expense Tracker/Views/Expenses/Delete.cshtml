@model Expense_Tracker.Models.Expense

@{
    ViewData["Title"] = "Delete";
}
<style>
    body {
        background: #0f172a;
        color: white;
        font-family: 'Segoe UI';
    }

    .wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 80vh;
    }

    .card {
        background: #020617;
        padding: 30px;
        border-radius: 12px;
        border: 1px solid #1e293b;
        text-align: center;
        width: 400px;
    }

    .danger {
        color: #ef4444;
        font-size: 18px;
        margin-bottom: 15px;
    }

    .btn {
        padding: 10px 15px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
    }

    .btn-danger {
        background: #ef4444;
        color: white;
    }

    .btn-secondary {
        background: #1e293b;
        color: white;
        text-decoration: none;
        margin-left: 10px;
    }
</style>

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Expense</h4>
    <hr />
    <div class="wrapper">
        <div class="card">

            <div class="danger">⚠ Delete Expense</div>

            <p>Are you sure you want to delete:</p>
            <strong>@Model.Description</strong>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />

                <br /><br />

                <button class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>

        </div>
    </div>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
